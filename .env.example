# Required for live discovery and YouTube statistics.
YOUTUBE_API_KEY=

# HTTP server. Use 0.0.0.0 inside a container or external host.
HOST=0.0.0.0
PORT=4173

# Default is same-origin. Set this when the frontend and API use different hosts.
PUBLIC_API_BASE_URL=
CORS_ORIGINS=
SESSION_COOKIE_NAME=viral_field_session
SESSION_DAYS=90
COOKIE_SECURE=false
# For a frontend hosted on a different site, use None together with HTTPS/Secure.
COOKIE_SAME_SITE=Lax

# The bundled adapter uses SQLite. The path may point to a persistent mounted disk.
DATABASE_URL=sqlite:./data/viral-field-v07.db

# Discovery worker schedule.
COLLECTOR_INTERVAL_MINUTES=15
SEARCH_INTERVAL_MINUTES=180
FEED_CANDIDATE_LIMIT=500
YOUTUBE_SEARCH_REGION=KR
YOUTUBE_SEARCH_LANGUAGE=ko
# Separate lanes with commas. The default four lanes use 32 search queries/day.
YOUTUBE_SEARCH_LANES=웃긴|밈|챌린지,강아지|고양이|반려동물,음식|요리|먹방,게임|엔터테인먼트
